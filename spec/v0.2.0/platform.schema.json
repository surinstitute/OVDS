{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ovds.xyz/spec/v0.2.0/platform.schema.json",
  "title": "Open Vehicle Data Standard - Platform",
  "type": "object",
  "additionalProperties": false,
  "required": ["id"],
  "properties": {
    "id": {
      "type": "string",
      "description": "OVDS platform identifier using a deterministic, human-readable uppercase slug.",
      "pattern": "^OVDS-PF-[A-Z0-9]+(?:-[A-Z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "description": "Display name of the platform."
    },
    "groupIds": {
      "type": "array",
      "description": "Automotive groups associated with this platform.",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^OVDS-GR-[A-Z0-9]+(?:-[A-Z0-9]+)*$"
      }
    },
    "makeIds": {
      "type": "array",
      "description": "Makes that use this platform.",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^OVDS-MK-[A-Z0-9]+(?:-[A-Z0-9]+)*$"
      }
    }
  }
}