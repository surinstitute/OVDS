{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://surinstitute.github.io/OVDS/v0.1.2/group.schema.json",
  "title": "Open Vehicle Data Standard - Group",
  "type": "object",
  "additionalProperties": false,
  "required": ["id"],
  "properties": {
    "id": {
      "type": "string",
      "description": "OVDS automotive group identifier using a deterministic, human-readable uppercase slug.",
      "pattern": "^OVDS-GR-[A-Z0-9]+(?:-[A-Z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "description": "Display name of the automotive group."
    }
  }
}